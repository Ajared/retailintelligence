# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_TYPE=postgres
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_ENTITIES=dist/**/*.entity{.ts,.js}
DB_MIGRATIONS=dist/migrations/*{.ts,.js}
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
EMAIL_JWT_EXPIRES_IN=15m
EMAIL_OTP_EXPIRES_IN=300

# Queue Configuration
QUEUE_TLS=false
QUEUE_HOST=localhost
QUEUE_PORT=5672
QUEUE_USERNAME=your_queue_username
QUEUE_PASSWORD=your_queue_password

# Email Configuration
SMTP_PORT=587
SMTP_HOST=smtp.example.com
SMTP_USER=your_smtp_username
SMTP_FROM=noreply@example.com
SMTP_PASS=your_smtp_password

# Auth Configuration
AUTH_CLIENT_ID=your_auth_client_id

# Admin Configuration
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your_secure_admin_password
